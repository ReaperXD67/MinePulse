{
  "name": "minepulse",
  "version": "0.1.0",
  "private": true,
  "description": "Minecraft server marketplace with verified playtime rewards, owner campaigns, and admin controls.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:apply": "node scripts/apply-sqlite-migration.mjs",
    "db:seed": "prisma db seed",
    "assets:generate": "node scripts/generate-assets.mjs",
    "game:test:up": "docker compose -f docker-compose.game-test.yml up -d",
    "game:test:logs": "docker compose -f docker-compose.game-test.yml logs -f paper",
    "game:test:status": "docker exec minepulse-paper-test rcon-cli plugins",
    "game:test:down": "docker compose -f docker-compose.game-test.yml down -v",
    "test:plugin-heartbeat": "tsx scripts/plugin-heartbeat-audit.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "playwright": "^1.61.0",
    "prisma": "^7.8.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
